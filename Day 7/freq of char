import java.util.Scanner;
public class freq {
    public static void main(String[] args) {
        Scanner in=new Scanner(System.in);
        String s=in.nextLine();
        int[] freq=new int[256];
        for(int i=0;i<s.length();i++){
            char c=s.charAt(i);
            freq[c]++;
        }
        for(int i=0;i<256;i++){
            if(freq[i]>0){
                System.out.println((char)i+" : "+freq[i]);
            }
        }
}
}
